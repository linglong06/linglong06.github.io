---
import { getCollection, render } from "astro:content";
import { labels, type Language } from "../../../lib/i18n";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { lang: post.data.lang, slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const lang = post.data.lang as Language;
const t = labels[lang];
const otherLang = t.otherLangCode;
const { Content } = await render(post);
---

<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={post.data.description} />
    <title>{post.data.title} | SleepLemon</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>SleepLemon</a>
      <nav aria-label="Main navigation">
        <a href={`/${lang}/blog`}>{t.guides}</a>
        <a href={`/${lang}/disclosure`}>{t.disclosure}</a>
        <a class="language-switch" href={`/${otherLang}/blog`}>{t.otherLang}</a>
      </nav>
    </header>
    <main class="article">
      <a class="back-link" href={`/${lang}/blog`}>{t.allGuides}</a>
      <p class="eyebrow">{post.data.category}</p>
      <h1>{post.data.title}</h1>
      <p class="dek">{post.data.description}</p>
      {post.data.affiliate && <p class="affiliate-banner">{t.affiliateText}</p>}
      <Content />
    </main>
    <footer>
      <span>© {new Date().getFullYear()} SleepLemon</span>
      <a href={`/${lang}/disclosure`}>{t.footerDisclosure}</a>
    </footer>
  </body>
</html>
