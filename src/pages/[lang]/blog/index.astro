---
import { getCollection } from "astro:content";
import { isLanguage, labels, languages } from "../../../lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : "en";
const t = labels[lang];
const otherLang = t.otherLangCode;
const posts = (await getCollection("posts"))
  .filter((post) => post.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.buyingGuides} | SleepLemon</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>SleepLemon</a>
      <nav aria-label="Main navigation">
        <a href={`/${lang}/blog`}>{t.guides}</a>
        <a href={`/${lang}/disclosure`}>{t.disclosure}</a>
        <a class="language-switch" href={`/${otherLang}/blog`}>{t.otherLang}</a>
      </nav>
    </header>
    <main class="narrow">
      <p class="eyebrow">{t.allGuides}</p>
      <h1>{t.buyingGuides}</h1>
      <div class="stack">
        {posts.map((post) => (
          <article class="post-row">
            <p class="eyebrow">{post.data.category}</p>
            <h2><a href={`/${lang}/blog/${post.slug}`}>{post.data.title}</a></h2>
            <p>{post.data.description}</p>
          </article>
        ))}
      </div>
    </main>
    <footer>
      <span>© {new Date().getFullYear()} SleepLemon</span>
      <a href={`/${lang}/disclosure`}>{t.footerDisclosure}</a>
    </footer>
  </body>
</html>
