---
import { isLanguage, labels, languages } from "../../lib/i18n";

export function getStaticPaths() {
  return languages.map((lang) => ({ params: { lang } }));
}

const langParam = Astro.params.lang;
const lang = isLanguage(langParam) ? langParam : "en";
const t = labels[lang];
const otherLang = t.otherLangCode;
---

<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{t.disclosureTitle} | SleepLemon</title>
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`/${lang}/`}>SleepLemon</a>
      <nav aria-label="Main navigation">
        <a href={`/${lang}/blog`}>{t.guides}</a>
        <a href={`/${lang}/disclosure`}>{t.disclosure}</a>
        <a class="language-switch" href={`/${otherLang}/disclosure`}>{t.otherLang}</a>
      </nav>
    </header>
    <main class="article">
      <h1>{t.disclosureTitle}</h1>
      <p>{t.affiliateText}</p>
      <p>{t.disclosureBody}</p>
      <p>{t.disclosureEthic}</p>
    </main>
    <footer>
      <span>© {new Date().getFullYear()} SleepLemon</span>
      <span>{t.affiliateText}</span>
    </footer>
  </body>
</html>
